{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MixFlip",
  "version": "0.1.0",
  "identifier": "audio.hornsupaudio.mixflip",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "MixFlip",
        "width": 820,
        "height": 920,
        "minWidth": 820,
        "maxWidth": 820,
        "minHeight": 920,
        "maxHeight": 920,
        "resizable": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
